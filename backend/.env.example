APP_NAME=EduPulse
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database — SQLite for development, MySQL for production
DATABASE_URL=sqlite:///./edupulse.db
# Production MySQL example:
# DATABASE_URL=mysql+pymysql://edupulse:password@db:3306/edupulse

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=replace-with-a-long-random-production-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["*"]

# ── Docker / Production Settings ──

# MySQL (used by docker-compose)
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=edupulse
MYSQL_USER=edupulse
MYSQL_PASSWORD=edupulse_secret

# Redis password (production)
# REDIS_PASSWORD=your-redis-password

# Gunicorn / Celery
GUNICORN_WORKERS=4
CELERY_CONCURRENCY=2

# Database seeding on startup
SEED_DB=false
